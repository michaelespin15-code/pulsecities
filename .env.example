# PulseCities environment variables
# Copy this file to .env and fill in real values — never commit .env

# PostgreSQL connection string
DATABASE_URL=postgresql://pulsecities_user:YOUR_PASSWORD@localhost/pulsecities

# NYC Open Data App Token — register free at:
# https://data.cityofnewyork.us/profile/edit/developer_settings
NYC_OPEN_DATA_APP_TOKEN=

# Anthropic API key — for AI neighborhood summaries (Phase 2+)
# https://console.anthropic.com
ANTHROPIC_API_KEY=

# SendGrid API key — for weekly email digests (Phase 4+)
SENDGRID_API_KEY=

# Google Earth Engine key path — for Sentinel-2 satellite imagery (v2)
# Requires GEE account + service account JSON key file
GOOGLE_EARTH_ENGINE_KEY=

# PurpleAir API key — for real-time air quality overlay (Phase 6)
# https://develop.purpleair.com
PURPLEAIR_API_KEY=

# Webhook URL for nightly pipeline failure alerts (Slack or Discord incoming webhook)
# Leave empty to disable webhook alerts (failures still logged to scraper.log)
ALERT_WEBHOOK_URL=

# Webhook payload format: "slack" (default) or "discord"
# Slack uses {"text": "..."}, Discord uses {"content": "..."}
ALERT_WEBHOOK_FORMAT=slack
